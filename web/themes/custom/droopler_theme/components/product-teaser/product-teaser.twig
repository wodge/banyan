{% set base_class = product_teaser_base_class|default('product-teaser') %}
{% set modifiers = product_teaser_modifiers|default([]) %}

<div {{ bem(base_class, modifiers) }}>
  <div {{ bem('image', [], base_class) }}>
    {{ main_image }}
  </div>
  <div {{ bem('product-content', [], base_class) }}>
    <div class="categories">
      {{ category }}
    </div>
    {{ title_prefix }}
    {% if label %}
      {% include 'droopler_theme:base-heading' with {
        heading_tag: 'h2',
        label: label
      } %}
    {% endif %}
    {{ title_suffix }}
  </div>
  <a {{ bem('link', [], base_class) }} href="{{ url }}" rel="bookmark"></a>
  <a href="{{ url }}" class="btn btn-primary btn-sm product-button">See product</a>
</div>
